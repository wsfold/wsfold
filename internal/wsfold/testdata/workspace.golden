{
  "folders": [
    {
      "name": "{{PRIMARY_NAME}}",
      "path": "."
    },
    {
      "name": "service",
      "path": "service"
    },
    {
      "name": "tool",
      "path": "{{EXTERNAL_RELATIVE_PATH}}"
    }
  ],
  "settings": {
    "files.exclude": {
      "service": true
    },
    "files.watcherExclude": {
      "service": true
    },
    "search.exclude": {
      "service": true
    }
  }
}
