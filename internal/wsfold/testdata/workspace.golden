{
  "folders": [
    {
      "name": "{{PRIMARY_NAME}}",
      "path": "{{PRIMARY_ROOT}}"
    },
    {
      "name": "service",
      "path": "/trusted/acme/service"
    },
    {
      "name": "tool",
      "path": "/external/legacy/tool"
    }
  ],
  "settings": {
    "files.exclude": {
      "_prj": true
    },
    "files.watcherExclude": {
      "_prj": true
    },
    "search.exclude": {
      "_prj": true
    }
  }
}
